<Project Sdk="Dalamud.CN.NET.Sdk/15.0.0">

  <PropertyGroup>
    <AssemblyName>HiAuRo</AssemblyName>
    <RootNamespace>HiAuRo</RootNamespace>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Version>0.1.10</Version>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../OmenTools/OmenTools.csproj" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Browsingway\Browsingway.Common\Browsingway.Common.csproj" />
    <ProjectReference Include="..\Browsingway\Browsingway\Browsingway.csproj" />
    <ProjectReference Include="..\Browsingway\Browsingway.Renderer\Browsingway.Renderer.csproj" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- Roslyn for TreeScriptNode dynamic compilation -->
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.13.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Common" Version="4.13.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="HiAuRo.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="UI/web/**\*.*" CopyToOutputDirectory="PreserveNewest" LinkBase="UI/web/" />
    <Compile Remove="Jobs\**" />
    <None Remove="Jobs\**" />
  </ItemGroup>

  <ItemGroup>
    <None Include="HiAuRo.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="UI/web/**\*.*" CopyToOutputDirectory="PreserveNewest" LinkBase="UI/web/" />
    <Compile Remove="Jobs\**" />
    <Compile Remove="Sdk\**" />
    <None Remove="Jobs\**" />
    <None Remove="Sdk\**" />
  </ItemGroup>

  <!-- 拷贝 Browsingway.Renderer.exe 到插件输出目录，并纳入 Dalamud 打包 -->
  <Target Name="CopyRendererOutput" AfterTargets="CoreBuild">
    <PropertyGroup>
      <_RendererSrc>..\Browsingway\out\</_RendererSrc>
    </PropertyGroup>
    <MakeDir Directories="$(OutputPath)renderer" Condition="Exists('$(_RendererSrc)Browsingway.Renderer.exe')" />
    <ItemGroup>
      <_RendererFiles Include="$(_RendererSrc)Browsingway.Renderer.*" />
      <_RendererFiles Include="$(_RendererSrc)Browsingway.Common.dll" />
      <_RendererFiles Include="$(_RendererSrc)CefSharp.OffScreen.dll" />
      <_RendererFiles Include="$(_RendererSrc)SharedMemory.dll" />
      <_RendererFiles Include="$(_RendererSrc)FlatSharp.Runtime.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_RendererFiles)" DestinationFolder="$(OutputPath)renderer" SkipUnchangedFiles="true" Condition="Exists('$(_RendererSrc)Browsingway.Renderer.exe')" />
    <!-- 声明为 Content 让 Dalamud 打包器识别并包含到 zip -->
    <ItemGroup Condition="Exists('$(_RendererSrc)Browsingway.Renderer.exe')">
      <Content Include="$(OutputPath)renderer\**\*" CopyToOutputDirectory="PreserveNewest" LinkBase="renderer\" Visible="false" />
    </ItemGroup>
  </Target>
  
</Project>
