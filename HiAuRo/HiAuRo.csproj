<Project Sdk="Dalamud.CN.NET.Sdk/15.0.0">

  <PropertyGroup>
    <AssemblyName>HiAuRo</AssemblyName>
    <RootNamespace>HiAuRo</RootNamespace>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Version>0.1.57</Version>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>CS1591</NoWarn>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
  </PropertyGroup>

  <!-- 编译时注入 Dev-时间戳 到 AssemblyInformationalVersion -->
  <Target Name="SetDevVersion" BeforeTargets="BeforeBuild">
    <PropertyGroup>
      <InformationalVersion>Dev-$([System.DateTime]::UtcNow.AddHours(8).ToString(yyyyMMdd-HHmm))</InformationalVersion>
    </PropertyGroup>
  </Target>

  <ItemGroup>
    <ProjectReference Include="../OmenTools/OmenTools.csproj" />
  </ItemGroup>

  <!-- Roslyn for TreeScriptNode dynamic compilation -->
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.13.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Common" Version="4.13.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="HiAuRo.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="UI/web/**\*.*" CopyToOutputDirectory="PreserveNewest" LinkBase="UI/web/" />
    <EmbeddedResource Include="Resources\Fonts\*.ttf" />
    <EmbeddedResource Include="Resources\blm_alpha.png" />
    <Compile Remove="Jobs\**" />
    <Compile Remove="Sdk\**" />
    <None Remove="Jobs\**" />
    <None Remove="Sdk\**" />
  </ItemGroup>

  
</Project>
